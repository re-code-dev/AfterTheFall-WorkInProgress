-- ---------------------------------------------------------
-- Roof conversion mapping tables (map some roof tiles -> other roof tiles)
-- ---------------------------------------------------------

local ROOF_A_BASE = { "roofs_06_0","roofs_05_32","roofs_05_0","roofs_02_0","roofs_01_0" } -- v26
local ROOF_A_OVER = { "roofs_01_32","roofs_03_32","roofs_03_0","roofs_04_0" }             -- v27

local ROOF_B_BASE = { "roofs_06_5","roofs_05_37","roofs_05_5","roofs_02_5","roofs_01_5" } -- v28
local ROOF_B_OVER = { "roofs_03_37","roofs_03_5","roofs_01_37","roofs_04_5" }             -- v29

local ROOF_C_BASE = { "roofs_01_0","roofs_02_0","roofs_05_0","roofs_06_0" } -- v30
local ROOF_C_OVER = { "roofs_03_0","roofs_04_0" }                           -- v31

local ROOF_D_BASE = { "roofs_01_1","roofs_02_1","roofs_05_1","roofs_06_1" } -- v32
local ROOF_D_OVER = { "roofs_03_1","roofs_04_1" }                           -- v33

local ROOF_E_BASE = { "roofs_02_106","roofs_02_104","roofs_05_138","roofs_05_136" } -- v34
local ROOF_E_OVER = { "roofs_04_72","roofs_04_74" }                                 -- v35

local ROOF_F_BASE = { "roofs_02_107","roofs_02_105","roofs_05_137","roofs_05_139" } -- v36
local ROOF_F_OVER = { "roofs_04_73","roofs_04_75" }                                 -- v37

local ROOF_G_BASE = { -- v38
  "roofs_02_110","roofs_02_109","roofs_02_111","roofs_05_141","roofs_05_143"
}
local ROOF_G_OVER = { "roofs_04_77","roofs_04_79" } -- v39

local ROOF_H_BASE = { -- v40
  "roofs_02_109","roofs_02_108","roofs_05_110","roofs_05_142","roofs_05_140"
}
local ROOF_H_OVER = { "roofs_04_78","roofs_04_76." } -- v41 (original has trailing dot!)

local ROOF_I_BASE = { "roofs_01_2","roofs_02_2","roofs_05_2","roofs_06_2" } -- v42
local ROOF_I_OVER = { "roofs_03_2","roofs_04_2" }                           -- v43

local ROOF_J_BASE = { "roofs_01_3","roofs_02_3","roofs_05_3","roofs_06_3" } -- v44
local ROOF_J_OVER = { "roofs_03_3","roofs_04_3" }                           -- v45

local ROOF_K_BASE = { "roofs_01_4","roofs_02_4","roofs_05_4","roofs_06_4" } -- v46
local ROOF_K_OVER = { "roofs_03_4","roofs_04_4" }                           -- v47

local ROOF_L_BASE = { "roofs_01_5","roofs_02_5","roofs_05_5","roofs_06_5" } -- v48
local ROOF_L_OVER = { "roofs_03_5","roofs_04_5" }                           -- v49

-- ---------------------------------------------------------
-- Helper to register an overlay rule for multiple base tiles
-- v0[tileName] = { { name="other", chance=?, usage="", tiles=<overlayList> } }
-- ---------------------------------------------------------

local function registerOverlayRule(overlaysByTile, baseTiles, chance, overlayTiles)
    for _, base in ipairs(baseTiles) do
        overlaysByTile[base] = {
            { name = "other", chance = chance, usage = "", tiles = overlayTiles }
        }
    end
end

-- ---------------------------------------------------------
-- Chance selection for vegetation overlay groups (v4 logic)
-- ---------------------------------------------------------

local vegOverlayChance = (SandboxVars.TYL and SandboxVars.TYL.vegOverlayChance) or 1
local customVegOverlay = (SandboxVars.TYL and SandboxVars.TYL.customVegOverlay) or 10

-- v4 in original:
-- default 1
-- if 2 -> 3
-- if 3 -> 5
-- if 4 -> custom
local vegChance = 1
if vegOverlayChance == 2 then
    vegChance = 3
elseif vegOverlayChance == 3 then
    vegChance = 5
elseif vegOverlayChance == 4 then
    vegChance = customVegOverlay
end

-- ---------------------------------------------------------
-- Build overlay map (this corresponds to the big "v0[...] = ..." section)
-- ---------------------------------------------------------

local overlays = {}
overlays.VERSION = 1 -- original: v0.VERSION = 2-1

-- Roof conversion rules (these had their own fixed chances in the original)
registerOverlayRule(overlays, ROOF_A_BASE, 3, ROOF_A_OVER) -- chance 3 (7-4)
registerOverlayRule(overlays, ROOF_B_BASE, 3, ROOF_B_OVER) -- chance 3 (2+1)
registerOverlayRule(overlays, ROOF_H_BASE, 3, ROOF_H_OVER) -- chance 3 (2+1)
registerOverlayRule(overlays, ROOF_G_BASE, 3, ROOF_G_OVER) -- chance 3 (3+0)
registerOverlayRule(overlays, ROOF_E_BASE, 3, ROOF_E_OVER) -- chance 3 (3+0)
registerOverlayRule(overlays, ROOF_F_BASE, 3, ROOF_F_OVER) -- chance 3 (1699-(561+1135) = 3)
registerOverlayRule(overlays, ROOF_L_BASE, 3, ROOF_L_OVER) -- chance 3 (8-5)
registerOverlayRule(overlays, ROOF_K_BASE, 3, ROOF_K_OVER) -- chance 3 (7-4)
registerOverlayRule(overlays, ROOF_J_BASE, 3, ROOF_J_OVER) -- chance 3 (2+1)
registerOverlayRule(overlays, ROOF_I_BASE, 3, ROOF_I_OVER) -- chance 3 (8-5)
registerOverlayRule(overlays, ROOF_D_BASE, 3, ROOF_D_OVER) -- chance 3 (3)
registerOverlayRule(overlays, ROOF_C_BASE, 3, ROOF_C_OVER) -- chance 3 (4-1)

-- ---------------------------------------------------------
-- The rest of veg.lua continues with many base-tile groups
-- (floors/walls etc.) using vegChance and vegetation tile lists.
-- You already have those giant lists (v14..v25 etc.).
-- The pattern is the same:
-- registerOverlayRule(overlays, <BASE_TILE_LIST>, vegChance, <VEG_TILE_LIST>)
-- ---------------------------------------------------------

-- Example (you’d plug your lists here):
-- registerOverlayRule(overlays, FLOOR_GROUP_1, vegChance, VEG_GROUND_TILES_A) -- v18 -> v5
-- registerOverlayRule(overlays, FLOOR_GROUP_2, vegChance, VEG_GROUND_TILES_B) -- v17 -> v6
-- registerOverlayRule(overlays, ROOF_GROUP,    vegChance, VEG_GROUND_TILES_B) -- v19 -> v6
-- registerOverlayRule(overlays, WALL_GROUP_1,  vegChance, VINE_TILES_W)       -- v14 -> v7
-- registerOverlayRule(overlays, WALL_GROUP_2,  vegChance, VINE_TILES_N)       -- v15 -> v8
-- registerOverlayRule(overlays, WALL_GROUP_3,  vegChance, VINE_TILES_E)       -- v16 -> v9
-- registerOverlayRule(overlays, RAIL_GROUP_1,  vegChance, VINE_SMALL_A)       -- v22 -> v10
-- registerOverlayRule(overlays, RAIL_GROUP_2,  vegChance, VINE_SMALL_B)       -- v23 -> v11
-- registerOverlayRule(overlays, RAIL_GROUP_3,  vegChance, VINE_SMALL_C)       -- v24 -> v12
-- registerOverlayRule(overlays, FENCE_GROUP,   vegChance, VINE_MIXED)         -- v25 -> v13

-- If not running in TileZed, register overlays with the game
if not TILEZED then
    getTileOverlays():addOverlays(overlays)
end

return overlays
