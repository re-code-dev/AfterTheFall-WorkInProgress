-- veg.lua (cleaned / deobfuscated)
-- Registers tile overlays for vegetation + wall vines + roof variants.
-- =========================================================

local overlays = {}
overlays.VERSION = 1

-- ---------------------------------------------------------
-- Sandbox config: veg overlay chance -> "chance" value used in overlay entries
-- ---------------------------------------------------------

local vegOverlayChanceSetting = (SandboxVars.TYL and SandboxVars.TYL.vegOverlayChance) or 1
local customVegOverlayChance  = (SandboxVars.TYL and SandboxVars.TYL.customVegOverlay) or 10

-- The original maps the Sandbox option into a numeric roll/chance value v4:
-- setting 2 -> 3
-- setting 3 -> 5
-- setting 4 -> custom
local vegChance = 1
if vegOverlayChanceSetting == 2 then
    vegChance = 3
elseif vegOverlayChanceSetting == 3 then
    vegChance = 5
elseif vegOverlayChanceSetting == 4 then
    vegChance = customVegOverlayChance
end

