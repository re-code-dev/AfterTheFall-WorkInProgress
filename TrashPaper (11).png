local WALL_N_LOW = {"f_wallvines_1_27","f_wallvines_1_26"}
local WALL_NW_LOW = {"f_wallvines_1_29","f_wallvines_1_28"}

local function startsWith(value, prefix)
    return value ~= nil and prefix ~= nil and string.sub(value, 1, #prefix) == prefix
end

local function clamp(value, minValue, maxValue)
    if value < minValue then return minValue end
    if value > maxValue then return maxValue end
    return value
end

local function floorSpriteName(square)
    local floor = square and square:getFloor()
    local sprite = floor and floor:getSprite()
    return sprite and sprite:getName() or nil
end

local function getOption(name, defaultValue)
    local atf = SandboxVars and SandboxVars.ATF
    if not atf then return defaultValue end
    local value = atf[name]
    if value == nil then return defaultValue end
    return value
end

local function ratioPair(a, b, defaultA, defaultB)
    a = tonumber(a) or defaultA
    b = tonumber(b) or defaultB
    if a < 0 then a = 0 end
    if b < 0 then b = 0 end
    if a == 0 and b == 0 then
        a, b = defaultA, defaultB
    end
    local total = a + b
    if total <= 0 then total = 1 end
    return a / total, b / total
end

local function getConfig()
    local treeChance = tonumber(getOption('TreeChance', 15)) or 15
    local treeScale = tonumber(getOption('TreeScale', 35)) or 35
    local bushChance = tonumber(getOption('BushChance', 6)) or 6
    local bushScale = tonumber(getOption('BushScale', 100)) or 100
    local grassChance = tonumber(getOption('GrassChance', 100)) or 100
    local groundcoverScale = tonumber(getOption('GroundcoverScale', 100)) or 100
    local roadOverlayChance = tonumber(getOption('RoadOverlayChance', 100)) or 100
    local sidewalkOverlayChance = tonumber(getOption('SidewalkOverlayChance', 100)) or 100
    local roofOverlayChance = tonumber(getOption('RoofOverlayChance', 20)) or 20
    local roofLeafRatio = tonumber(getOption('RoofLeafRatio', 60)) or 60
    local vinesChance = tonumber(getOption('VinesChance', 15)) or 15
    local noTreesOnRoad = getOption('noTreesOnRoad', false) == true
    local roadGrassRatio, roadMossRatio = ratioPair(getOption('RoadGrassRatio', 75), getOption('RoadMossRatio', 25), 75, 25)
    local sidewalkGrassRatio, sidewalkMossRatio = ratioPair(getOption('SidewalkGrassRatio', 60), getOption('SidewalkMossRatio', 40), 60, 40)

    return {
        treeDensity = clamp((treeChance / 100) * (treeScale / 100) * 1.5, 0, 1),
        bushDensity = clamp((bushChance / 100) * (bushScale / 100), 0, 1),
        groundcoverDensity = clamp((grassChance / 100) * (groundcoverScale / 100), 0, 1),
        roadOverlayChance = clamp(roadOverlayChance / 100, 0, 1),
        sidewalkOverlayChance = clamp(sidewalkOverlayChance / 100, 0, 1),
        roofOverlayChance = clamp(roofOverlayChance / 100, 0, 1),
        roofLeafRatio = clamp(roofLeafRatio / 100, 0, 1),
        vinesChance = clamp(vinesChance / 100, 0, 1),
        roadGrassRatio = roadGrassRatio,
        roadMossRatio = roadMossRatio,
        sidewalkGrassRatio = sidewalkGrassRatio,
        sidewalkMossRatio = sidewalkMossRatio,
        noTreesOnRoad = noTreesOnRoad,
    }
end

local function propertyNames(obj)
    local sprite = obj and obj:getSprite()
    local props = sprite and sprite:getProperties()
    local names = props and props:getPropertyNames()
    return names and tostring(names) or ""
end

local function hasProperty(obj, key)
    local names = propertyNames(obj)
    return names ~= "" and string.find(names, key, 1, true) ~= nil
end

local function squareIsUsable(square)
    if not square then return false end
    if not square:hasFloor(true) then return false end
    if square:HasStairs() then return false end
    if square:getRoom() ~= nil then return false end
    if not square:isOutside() then return false end
    if square:isSolid() then return false end
    if square:isSolidTrans() then return false end
    local objects = square:getObjects()
    if not objects then return true end
    for i = 0, objects:size() - 1 do
        local obj = objects:get(i)
        if obj then
            if instanceof(obj, 'IsoWindow') or instanceof(obj, 'IsoDoor') then return false end
        end
    end
    return true
end

local function hasPrefixObject(square, prefix)
    local objects = square and square:getObjects()
    if not objects then return false end
    for i = 0, objects:size() - 1 do
        local obj = objects:get(i)
        if obj then
            local spriteName = obj.getSpriteName and obj:getSpriteName() or nil
            local textureName = obj.getTextureName and obj:getTextureName() or nil
            local name = spriteName or textureName
            if name and startsWith(name, prefix) then return true end
        end
    end
    return false
end

local function hasAnyGrowth(square)
    local objects = square and square:getObjects()
    if not objects then return false end
    for i = 0, objects:size() - 1 do
        local obj = objects:get(i)
        if obj then
            if instanceof(obj, 'IsoTree') then return true end
            local spriteName = obj.getSpriteName and obj:getSpriteName() or nil
            local textureName = obj.getTextureName and obj:getTextureName() or nil
            local name = spriteName or textureName
            if name then
                if startsWith(name, 'e_') or startsWith(name, 'f_bushes_') or startsWith(name, 'd_floorleaves_') or startsWith(name, 'f_wallvines_') then
                    return true
                end
            end
        end
    end
    return false
end

local function isRoadSquare(square)
    local floorName = floorSpriteName(square)
    return floorName and ROAD_TILES[floorName] == true or false
end

local function isSidewalkSquare(square)
    local floorName = floorSpriteName(square)
    if not floorName or ROAD_TILES[floorName] then return false end
    if startsWith(floorName, 'blends_street_') or startsWith(floorName, 'floors_exterior_street_') or startsWith(floorName, 'floors_exterior_tilesandstone_') then
        return true
    end
    if string.find(floorName, 'sidewalk', 1, true) or string.find(floorName, 'pavement', 1, true) or string.find(floorName, 'concrete', 1, true) then
        return true
    end
    return false
end

local function isFlatRoofSquare(square)
    local z = square:getZ()
    if z <= 0 then return false end
    if square:getRoom() ~= nil then return false end
    if not square:isOutside() then return false end
    local floorName = floorSpriteName(square)
    if not floorName then return false end
    if FLAT_ROOF_TILES[floorName] then return true end
    if startsWith(floorName, 'roofs_') or startsWith(floorName, 'roofs_accents_') or startsWith(floorName, 'roofs_exterior_') then
        return true
    end
    return false
end

local function addIsoObject(square, spriteName, tileObject)
    if not square or not spriteName then return nil end
    local chunk = square.getChunk and square:getChunk() or nil
    if not chunk then return nil end
    local obj = IsoObject.new(getCell(), square, spriteName)
    if not obj then return nil end
    if tileObject then
        square:AddTileObject(obj)
    else
        square:AddSpecialObject(obj)
    end
    square:RecalcProperties()
    obj:transmitCompleteItemToClients()
    obj:transmitModData()
    return obj
end

local function maybeRoadGrowth(square, chance, grassRatio, mossRatio, modData)
    if chance <= 0 or ZombRandFloat(0, 1) >= chance then return end
    local spriteName
    if ZombRandFloat(0, 1) < grassRatio then
        spriteName = ROAD_GRASS_POOL[ZombRand(#ROAD_GRASS_POOL) + 1]
    else
        spriteName = LEAF_POOL[ZombRand(#LEAF_POOL) + 1]
    end
    if addIsoObject(square, spriteName, false) then
        modData.ATF_roadGrowth = true
    end
end

local function maybeGroundcover(square, chance, modData)
    if chance <= 0 or ZombRandFloat(0, 1) >= chance then return end
    local pool = ZombRand(3) == 0 and LEAF_POOL or GROUND_GRASS_POOL
    local spriteName = pool[ZombRand(#pool) + 1]
    if addIsoObject(square, spriteName, false) then
        modData.ATF_groundGrowth = true
    end
end

local function maybeBush(square, chance, modData)
    if chance <= 0 or ZombRandFloat(0, 1) >= chance then return end
    if hasPrefixObject(square, 'f_bushes_') then return end
    local spriteName = BUSH_POOL[ZombRand(#BUSH_POOL) + 1]
    if addIsoObject(square, spriteName, false) then
        modData.ATF_bush = true
    end
end

local function maybeRoofGrowth(square, cfg, modData)
    if cfg.roofOverlayChance <= 0 or ZombRandFloat(0, 1) >= cfg.roofOverlayChance then return end
    local spriteName
    if ZombRandFloat(0, 1) < cfg.roofLeafRatio then
        spriteName = LEAF_POOL[ZombRand(#LEAF_POOL) + 1]
    else
        spriteName = ROAD_GRASS_POOL[ZombRand(#ROAD_GRASS_POOL) + 1]
    end
    if addIsoObject(square, spriteName, false) then
        modData.ATF_roofGrowth = true
    end
end

local function maybeTree(square, chance, modData, smallOnly)
    if chance <= 0 or ZombRandFloat(0, 1) >= chance then return end
    local chunk = square.getChunk and square:getChunk() or nil
    if not chunk then return end
    local spriteName = smallOnly and SMALL_TREE_POOL[ZombRand(#SMALL_TREE_POOL) + 1] or TREE_POOL[ZombRand(#TREE_POOL) + 1]
    local sprite = getSprite(spriteName)
    if not sprite then return end
    local tree = IsoTree.new(square, sprite)
    if not tree then return end
    square:AddSpecialObject(tree)
    square:RecalcProperties()
    tree:transmitCompleteItemToClients()
    tree:transmitModData()
    modData.ATF_serverTree = true
end

local function hasVines(square)
    return hasPrefixObject(square, 'f_wallvines_')
end

local function vinePoolFor(obj)
    local texture = obj.getTextureName and obj:getTextureName() or ''
    local low = hasProperty(obj, 'FenceTypeLow') or startsWith(texture, 'fixtures_railings')
    if hasProperty(obj, 'WallNW') then
        return low and WALL_NW_LOW or WALL_NW
    end
    if hasProperty(obj, 'WallW') or hasProperty(obj, 'WindowW') or hasProperty(obj, 'DoorWallW') or hasProperty(obj, 'attachedW') or hasProperty(obj, 'WallWTrans') then
        return low and WALL_W_LOW or WALL_W
    end
    if hasProperty(obj, 'WallN') or hasProperty(obj, 'WindowN') or hasProperty(obj, 'DoorWallN') then
        return low and WALL_N_LOW or WALL_N
    end
    return nil
end

local function maybeVines(square, chance, modData)
    if chance <= 0 or ZombRandFloat(0, 1) >= chance then return end
    if hasVines(square) then return end
    local objects = square:getObjects()
    if not objects then return end
    for i = 0, objects:size() - 1 do
        local obj = objects:get(i)
        if obj then
            local texture = obj.getTextureName and obj:getTextureName() or nil
            if texture and not startsWith(texture, 'walls_detailling') and not startsWith(texture, 'walls_exterior_roofs') then
                local pool = vinePoolFor(obj)
                if pool then
                    local spriteName = pool[ZombRand(#pool) + 1]
                    if addIsoObject(square, spriteName, true) then
                        modData.ATF_vines = true
                        return
                    end
                end
            end
        end
    end
end

local function loadSquare(square)
    if not square then return end
    local z = square:getZ()
    if z < 0 or z > 7 then return end
    local modData = square:getModData()
    if modData.ATF_cleanB42 then return end

    local cfg = getConfig()
    local outside = square:getRoom() == nil and square:isOutside()
    local floorName = floorSpriteName(square)
    local road = floorName and ROAD_TILES[floorName] == true or false
    local sidewalk = (not road) and isSidewalkSquare(square)
    local natural = floorName and NATURAL_TILES[floorName] == true or false
    local roof = isFlatRoofSquare(square)

    if outside and roof and squareIsUsable(square) and not hasAnyGrowth(square) then
        maybeRoofGrowth(square, cfg, modData)
    elseif outside and squareIsUsable(square) and z == 0 and not hasAnyGrowth(square) then
        if road then
            maybeRoadGrowth(square, cfg.roadOverlayChance, cfg.roadGrassRatio, cfg.roadMossRatio, modData)
            if not cfg.noTreesOnRoad then
                maybeTree(square, cfg.treeDensity * 0.35, modData, true)
            end
        elseif sidewalk then
            maybeRoadGrowth(square, cfg.sidewalkOverlayChance, cfg.sidewalkGrassRatio, cfg.sidewalkMossRatio, modData)
        else
            maybeGroundcover(square, cfg.groundcoverDensity, modData)
            maybeBush(square, cfg.bushDensity, modData)
            if natural or not road then
                maybeTree(square, cfg.treeDensity, modData, false)
            end
        end
    end

    if outside and not square:isSolid() and not square:isSolidTrans() then
        maybeVines(square, cfg.vinesChance, modData)
    end

    modData.ATF_cleanB42 = true
    square:transmitModdata()
end

Events.LoadGridsquare.Add(loadSquare)
